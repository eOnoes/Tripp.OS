{
  "name": "@tripp-os/workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Tripp.OS workspace — agent-bus and runtime-trace packages",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces",
    "build": "npm run build --workspaces",
    "test": "npm run build --workspace=packages/agent-bus && npm test --workspace=packages/runtime-trace"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}
